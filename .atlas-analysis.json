  "keyFeatures": [
    "TV show tracking with watchlist, watching, completed, and dropped statuses",
    "Episode-level progress tracking and logging",
    "Social features with following, reviews, likes, and comments",
    "AI-powered recommendations using embeddings and taste matching",
    "Release calendar for upcoming episodes and premieres",
    "Contact sync for friend discovery",
    "Public and private lists with drag-and-drop reordering",
    "Phone-based authentication with OTP",
    "TMDB integration for show metadata and catalog"
  ],
  "publicApiSurface": [
    "users - Profile management, onboarding, visibility controls",
    "shows - TMDB ingestion, catalog search, show details",
    "watchStates - Track show status (watchlist/watching/completed/dropped)",
    "watchLogs - Log watched episodes and shows",
    "episodeProgress - Track episode-level progress",
    "reviews - Create and manage show/episode reviews",
    "follows - Social graph and following relationships",
    "lists - User-curated show collections",
    "feedItems - Personalized activity feed",
    "releaseCalendar - Upcoming episodes and premieres",
    "embeddings - Taste profiles and recommendations",
    "contacts - Contact sync and friend discovery",
    "likes - Like reviews, logs, and lists",
    "comments - Comment on user content",
    "reports - Content moderation"
  ]
}
